{
  "name": "practical-calculators",
  "private": true,
  "version": "1.0.0",
  "description": "Static calculator pages with generation and validation tooling",
  "scripts": {
    "update:rates": "node scripts/update-rates.js",
    "generate:pages": "npm run update:rates && node scripts/generate-pages.js && node scripts/migrate-layout.js",
    "migrate:layout": "node scripts/migrate-layout.js",
    "validate:pages": "node scripts/validate-pages.js",
    "test:apr": "node scripts/test-apr-math.js",
    "report:indexability": "node scripts/report-indexability.js",
    "refresh:inventory": "node scripts/refresh-pages-inventory.js",
    "deploy:worker": "wrangler deploy --config workers/frankfurter-cors-proxy/wrangler.toml"
  },
  "devDependencies": {
    "wrangler": "^4.83.0"
  }
}
